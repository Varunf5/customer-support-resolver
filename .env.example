# Example Environment Variables
# Copy this to .env and fill in your values

# OpenAI Configuration
OPENAI_API_KEY=sk-your-api-key-here
API_BASE_URL=https://api.openai.com/v1
MODEL_NAME=gpt-4

# HuggingFace Token (optional, for HF model access)
HF_TOKEN=hf_your-token-here

# Server Configuration (for Flask app)
HOST=0.0.0.0
PORT=7860
DEBUG=False

# Runtime Configuration (for Docker)
# Set CMD_TYPE=flask to run Flask app instead of inference
# Leave unset or CMD_TYPE=inference for default inference mode
CMD_TYPE=inference

# Logging Configuration (optional)
# LOG_LEVEL=INFO
# PYTHONUNBUFFERED=1
